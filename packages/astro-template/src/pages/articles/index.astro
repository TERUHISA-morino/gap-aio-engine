---
import BaseLayout from '../../layouts/BaseLayout.astro';
import clientConfig from '../../client-config.js';
import { getAllArticles } from '../../lib/articles.js';

const articles = getAllArticles();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: '症状解説記事一覧',
  description: `${clientConfig.name}の症状解説記事`,
  url: new URL('/articles/', Astro.site).toString(),
};
---

<BaseLayout title="症状解説記事一覧" description={`${clientConfig.name}の症状解説記事一覧`} jsonLd={jsonLd}>
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-6">
      <h1 class="font-serif text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
        症状解説記事一覧
      </h1>
      <p class="mt-4 text-sm text-slate-600">
        全 {articles.length} 件の記事 ／ GAP理論に基づく独自の考察
      </p>

      <div class="mt-10 space-y-4">
        {articles.length === 0 ? (
          <p class="text-slate-500">記事を準備中です。</p>
        ) : articles.map((a) => (
          <a href={`/articles/${a.slug}/`}
             class="group block rounded-2xl border border-slate-200 bg-white p-6 transition hover:border-emerald-300 hover:shadow-md">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="mb-2 flex items-center gap-3 text-xs text-slate-500">
                  <span>{a.data.date}</span>
                  <span class="text-slate-300">／</span>
                  <span>{a.data.category || '症状解説'}</span>
                </div>
                <h2 class="font-serif text-lg font-bold leading-snug text-slate-900 group-hover:text-emerald-700 md:text-xl">
                  {a.data.title}
                </h2>
                {a.data.excerpt && (
                  <p class="mt-3 text-sm leading-relaxed text-slate-600 line-clamp-2">{a.data.excerpt}</p>
                )}
              </div>
              <div class="hidden text-emerald-700 opacity-0 transition group-hover:opacity-100 md:block">→</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
