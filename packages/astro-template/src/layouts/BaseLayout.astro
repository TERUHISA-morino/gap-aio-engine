---
import clientConfig from '../client-config.js';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: object;
}

const {
  title,
  description = clientConfig.tagline,
  ogImage,
  jsonLd,
} = Astro.props;

const fullTitle = `${title} | ${clientConfig.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={clientConfig.author} />
    <link rel="canonical" href={canonical} />

    <!-- OGP / Twitter Card -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={clientConfig.name} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Performance hints (AIO/SEO) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={clientConfig.name} href="/rss.xml" />

    <title>{fullTitle}</title>

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
    )}
  </head>
  <body class="bg-white font-sans text-slate-900 antialiased">
    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-4xl items-center justify-between px-6 py-5">
        <a href="/" class="font-serif text-xl font-bold text-slate-900 hover:text-emerald-700">
          {clientConfig.name}
        </a>
        <nav class="flex gap-6 text-sm text-slate-600">
          <a href="/" class="hover:text-slate-900">トップ</a>
          <a href="/articles/" class="hover:text-slate-900">症状解説</a>
          <a href={clientConfig.contactUrl || '#'} class="rounded-full bg-emerald-600 px-4 py-1.5 text-white hover:bg-emerald-700">
            来院相談
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-20 border-t border-slate-200 bg-slate-50 py-12">
      <div class="mx-auto max-w-4xl px-6 text-sm text-slate-600">
        <div class="font-serif text-base font-bold text-slate-900">{clientConfig.name}</div>
        <p class="mt-2 leading-relaxed">{clientConfig.tagline}</p>
        {clientConfig.address && <p class="mt-3 text-xs text-slate-500">{clientConfig.address}</p>}
        <p class="mt-6 text-xs text-slate-400">
          © {new Date().getFullYear()} {clientConfig.name}. Powered by GAP-AIO.
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  html { scroll-behavior: smooth; }
  ::selection { background-color: rgba(16, 185, 129, 0.2); }
  .prose-article p { margin: 1em 0; line-height: 1.9; }
  .prose-article h2 { margin-top: 2em; margin-bottom: 0.5em; font-size: 1.5em; font-weight: 700; }
  .prose-article h3 { margin-top: 1.5em; margin-bottom: 0.5em; font-size: 1.2em; font-weight: 700; }
  .prose-article ul { margin: 1em 0; padding-left: 1.5em; list-style: disc; }
  .prose-article li { margin: 0.4em 0; }
  .prose-article strong { color: #047857; }
</style>
