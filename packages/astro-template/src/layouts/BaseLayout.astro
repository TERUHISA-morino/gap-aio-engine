---
import clientConfig from '../client-config.js';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: object;
}

const {
  title,
  description = clientConfig.tagline,
  ogImage,
  jsonLd,
} = Astro.props;

const fullTitle = `${title} | ${clientConfig.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const t = clientConfig.theme;
const titleFontClass = t.fontTitle === 'sans' ? 'font-sans' : 'font-serif';
const isDark = t.presetName === 'premium-dark';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={clientConfig.name} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={clientConfig.name} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Noto+Serif+JP:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={clientConfig.name} href="/rss.xml" />

    <title>{fullTitle}</title>

    <style is:inline define:vars={{primary: t.primary, primaryDark: t.primaryDark, accent: t.accent}}>
      :root { --c-primary: var(--primary); --c-primary-dark: var(--primaryDark); --c-accent: var(--accent); }
      .bg-primary { background-color: var(--c-primary); }
      .bg-primary-dark { background-color: var(--c-primary-dark); }
      .text-primary { color: var(--c-primary); }
      .text-primary-dark { color: var(--c-primary-dark); }
      .border-primary { border-color: var(--c-primary); }
      .text-accent { color: var(--c-accent); }
      .bg-accent { background-color: var(--c-accent); }
      .ring-primary { --tw-ring-color: var(--c-primary); }
      .hover\\:bg-primary:hover { background-color: var(--c-primary); }
      .hover\\:bg-primary-dark:hover { background-color: var(--c-primary-dark); }
      .hover\\:text-primary:hover { color: var(--c-primary); }
    </style>

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
    )}
  </head>
  <body class={`${isDark ? 'bg-slate-900 text-slate-100' : 'bg-white text-slate-800'} antialiased`}>

    <!-- Sticky CTA Header -->
    <header class={`sticky top-0 z-50 border-b ${isDark ? 'border-slate-700 bg-slate-900/95' : 'border-slate-200 bg-white/95'} backdrop-blur`}>
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 md:px-6 md:py-4">
        <a href="/" class={`${titleFontClass} text-base font-bold tracking-tight md:text-lg`}>
          <span class="text-primary">{clientConfig.shortName || clientConfig.name}</span>
        </a>
        <nav class="hidden items-center gap-5 text-xs md:flex">
          <a href="#features" class="hover:text-primary">特徴</a>
          <a href="#symptoms" class="hover:text-primary">症状別</a>
          <a href="#menu" class="hover:text-primary">料金</a>
          <a href="#staff" class="hover:text-primary">院長</a>
          <a href="#voices" class="hover:text-primary">お客様の声</a>
          <a href="/articles/" class="hover:text-primary">症状解説</a>
          <a href="#access" class="hover:text-primary">アクセス</a>
        </nav>
        <div class="flex items-center gap-2">
          {clientConfig.phone && (
            <a href={`tel:${clientConfig.phone}`} class={`hidden items-center gap-1 rounded-full border px-3 py-1.5 text-xs font-medium md:inline-flex ${isDark ? 'border-slate-600 text-slate-200' : 'border-slate-300 text-slate-700'}`}>
              📞 {clientConfig.phone}
            </a>
          )}
          {clientConfig.lineUrl && (
            <a href={clientConfig.lineUrl} target="_blank" rel="noopener"
               class="inline-flex items-center gap-1 rounded-full bg-primary px-3 py-1.5 text-xs font-bold text-white hover:bg-primary-dark md:px-4 md:py-2">
              LINE予約 →
            </a>
          )}
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class={`mt-20 border-t ${isDark ? 'border-slate-700 bg-slate-900' : 'border-slate-200 bg-slate-50'} py-12`}>
      <div class="mx-auto max-w-6xl px-6">
        <div class="grid gap-10 md:grid-cols-3">
          <div>
            <div class={`${titleFontClass} text-lg font-bold`}>{clientConfig.name}</div>
            <p class={`mt-3 text-sm leading-relaxed ${isDark ? 'text-slate-400' : 'text-slate-600'}`}>
              {clientConfig.tagline}
            </p>
            {clientConfig.addressDetail && <p class={`mt-3 text-xs ${isDark ? 'text-slate-500' : 'text-slate-500'}`}>{clientConfig.addressDetail}</p>}
            {clientConfig.stationAccess && <p class={`mt-1 text-xs ${isDark ? 'text-slate-500' : 'text-slate-500'}`}>{clientConfig.stationAccess}</p>}
          </div>

          <div>
            <div class="text-xs font-bold tracking-widest text-primary">CONTACT</div>
            <div class="mt-3 space-y-1.5 text-sm">
              {clientConfig.phone && <a href={`tel:${clientConfig.phone}`} class="block hover:text-primary">📞 {clientConfig.phone}</a>}
              {clientConfig.lineUrl && <a href={clientConfig.lineUrl} class="block hover:text-primary" target="_blank" rel="noopener">💬 LINE予約</a>}
              {clientConfig.openHours && <p class={isDark ? 'text-slate-400' : 'text-slate-600'}>🕒 {clientConfig.openHours}</p>}
              {clientConfig.closedDays && <p class={isDark ? 'text-slate-400' : 'text-slate-600'}>{clientConfig.closedDays}</p>}
            </div>
          </div>

          <div>
            <div class="text-xs font-bold tracking-widest text-primary">MENU</div>
            <nav class={`mt-3 grid grid-cols-2 gap-1.5 text-sm ${isDark ? 'text-slate-400' : 'text-slate-600'}`}>
              <a href="#features" class="hover:text-primary">特徴</a>
              <a href="#symptoms" class="hover:text-primary">症状別</a>
              <a href="#menu" class="hover:text-primary">料金</a>
              <a href="#staff" class="hover:text-primary">院長</a>
              <a href="#voices" class="hover:text-primary">お客様の声</a>
              <a href="/articles/" class="hover:text-primary">症状解説</a>
              <a href="#access" class="hover:text-primary">アクセス</a>
            </nav>
            {(clientConfig.instagramUrl || clientConfig.youtubeUrl || clientConfig.twitterUrl) && (
              <div class="mt-5 flex gap-3 text-sm">
                {clientConfig.instagramUrl && <a href={clientConfig.instagramUrl} target="_blank" rel="noopener" class="hover:text-primary">Instagram</a>}
                {clientConfig.youtubeUrl && <a href={clientConfig.youtubeUrl} target="_blank" rel="noopener" class="hover:text-primary">YouTube</a>}
                {clientConfig.twitterUrl && <a href={clientConfig.twitterUrl} target="_blank" rel="noopener" class="hover:text-primary">X (Twitter)</a>}
              </div>
            )}
          </div>
        </div>

        <div class={`mt-10 border-t ${isDark ? 'border-slate-700' : 'border-slate-200'} pt-6 text-[11px] ${isDark ? 'text-slate-500' : 'text-slate-400'}`}>
          © {new Date().getFullYear()} {clientConfig.name}. All rights reserved. ／ Powered by GAP-AIO
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  html { scroll-behavior: smooth; scroll-padding-top: 64px; }
  ::selection { background-color: rgba(4, 120, 87, 0.2); }
  .prose-article p { margin: 1em 0; line-height: 1.95; }
  .prose-article h2 { margin-top: 2.4em; margin-bottom: 0.6em; font-size: 1.5em; font-weight: 700; padding-bottom: 0.3em; border-bottom: 2px solid currentColor; opacity: 0.95; }
  .prose-article h3 { margin-top: 1.8em; margin-bottom: 0.5em; font-size: 1.2em; font-weight: 700; }
  .prose-article ul { margin: 1em 0; padding-left: 1.5em; list-style: disc; }
  .prose-article li { margin: 0.4em 0; }
  .prose-article strong { color: var(--c-primary); }
</style>
